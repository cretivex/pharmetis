# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/pharmetis?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT=30000

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# PASSWORD HASHING
# ============================================
BCRYPT_SALT_ROUNDS=12

# ============================================
# CORS & SECURITY
# ============================================
# Production (comma-separated). For local dev use http://localhost:5173,http://localhost:5174,http://localhost:5175
CORS_ORIGIN=https://pharmetis.in,https://admin.pharmetis.in,https://supplier.pharmetis.in
FRONTEND_SUPPLIER_URL=https://supplier.pharmetis.in
CORS_CREDENTIALS=true
COOKIE_SECRET=your-super-secret-cookie-key-change-in-production-min-32-chars
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_HTTP_ONLY=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ============================================
# API CONFIGURATION
# ============================================
API_PREFIX=/api
API_VERSION=v1

# ============================================
# HELMET SECURITY
# ============================================
HELMET_CONTENT_SECURITY_POLICY=true
HELMET_HSTS_MAX_AGE=31536000

# ============================================
# SESSION (if using sessions)
# ============================================
SESSION_SECRET=your-super-secret-session-key-change-in-production-min-32-chars
SESSION_MAX_AGE=86400000

# ============================================
# FILE UPLOAD (if applicable)
# ============================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
