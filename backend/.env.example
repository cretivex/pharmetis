# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# DATABASE
# ============================================
# Local:
DATABASE_URL=postgresql://user:password@localhost:5432/pharmetis?schema=public
#
# AWS RDS PostgreSQL (use sslmode=require; URL-encode special chars in password):
# DATABASE_URL=postgresql://USER:PASSWORD@your-db.xxxx.region.rds.amazonaws.com:5432/pharmetis?schema=public&sslmode=require
#
# See prisma/RDS_MIGRATION.md for migrate deploy steps.
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT=30000

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d
# Must be the exact same string as VITE_PAYLOAD_SECRET in each Vite app (.env)
PAYLOAD_SECRET=replace-with-strong-aes-secret

# ============================================
# PASSWORD HASHING
# ============================================
BCRYPT_SALT_ROUNDS=12

# ============================================
# CORS & SECURITY
# ============================================
# Comma-separated origins. If omitted, env.js defaults include localhost:5173–5175 + pharmetis domains.
# Local dev example:
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175
CORS_ORIGIN=https://pharmetis.in,https://admin.pharmetis.in,https://supplier.pharmetis.in
FRONTEND_SUPPLIER_URL=http://localhost:5175
CORS_CREDENTIALS=true
COOKIE_SECRET=your-super-secret-cookie-key-change-in-production-min-32-chars
# Dev: false + Lax. Production HTTPS: typically true. Cross-site SPA (e.g. app on another host than API): COOKIE_SAME_SITE=None requires COOKIE_SECURE=true.
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
COOKIE_HTTP_ONLY=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Auth routes: /auth/login, /auth/register, /auth/logout, /auth/refresh
# Defaults: development = 200 requests per 1 minute; production = 5 per 15 minutes
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=5

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ============================================
# API CONFIGURATION
# ============================================
API_PREFIX=/api
API_VERSION=v1

# ============================================
# HELMET SECURITY
# ============================================
HELMET_CONTENT_SECURITY_POLICY=true
HELMET_HSTS_MAX_AGE=31536000

# ============================================
# SESSION (if using sessions)
# ============================================
SESSION_SECRET=your-super-secret-session-key-change-in-production-min-32-chars
SESSION_MAX_AGE=86400000

# ============================================
# FILE UPLOAD (if applicable)
# ============================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
