{
  "name": "pharmetis-backend",
  "version": "1.0.0",
  "description": "Production-ready Node.js backend for Pharmetis B2B pharmaceutical marketplace",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "seed": "node prisma/seed.js",
    "cleanup": "node scripts/cleanup-dummy-data.js",
    "db:test": "node scripts/test-connection.js",
    "db:verify": "node scripts/verify-tables.js",
    "db:create": "node scripts/create-database.js",
    "db:fix": "node scripts/fix-all-tables.js",
    "db:check": "node scripts/check-database-tables.js",
    "db:setup-ali": "node scripts/create-and-check-ali.js",
    "verify:seed-user": "node scripts/verify-seed-user.js",
    "worker": "node src/workers/index.js"
  },
  "keywords": [
    "pharmaceutical",
    "b2b",
    "marketplace",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@prisma/client": "^5.7.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.5",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "axios": "^1.13.5",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.1"
  }
}
